generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  SUPPORT_ADMIN
  SYSTEM_AUDITOR
  SCHOOL_OWNER
  HEADMASTER
  VICE_PRINCIPAL
  SCHOOL_ADMIN
  ACADEMIC_COORDINATOR
  ADMIN_OFFICER
  TEACHER
  HEAD_OF_DEPARTMENT
  CLASS_TEACHER
  EXAM_OFFICER
  LAB_INSTRUCTOR
  SUBSTITUTE_TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  RECEPTIONIST
  LIBRARIAN
  IT_ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  TRANSFERRED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum AcademicTerm {
  FIRST_TERM
  SECOND_TERM
  THIRD_TERM
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model School {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  slug               String              @unique
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  users              User[]
  staff              StaffProfile[]
  classes            SchoolClass[]
  students           StudentProfile[]
  studentEnrollments StudentEnrollment[]
  attendanceSessions AttendanceSession[]
  attendanceEntries  AttendanceEntry[]
  subjects           Subject[]
  exams              Exam[]
  examResults        ExamResult[]
  notifications      Notification[]
  auditLogs          AuditLog[]

  @@map("schools")
}

model User {
  id                   String              @id @default(uuid()) @db.Uuid
  /// Nullable only for SaaS platform roles: SUPER_ADMIN, SUPPORT_ADMIN, SYSTEM_AUDITOR.
  schoolId             String?             @map("school_id") @db.Uuid
  school               School?             @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  email                String              @unique
  passwordHash         String              @map("password_hash")
  role                 Role
  isActive             Boolean             @default(true) @map("is_active")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  refreshTokens        RefreshToken[]
  auditLogs            AuditLog[]
  teachingClasses      SchoolClass[]       @relation("ClassTeacher")
  staffProfile         StaffProfile?       @relation("StaffUser")
  studentProfile       StudentProfile?     @relation("StudentUser")
  attendanceTaken      AttendanceSession[] @relation("AttendanceTakenBy")
  examsCreated         Exam[]              @relation("ExamCreatedBy")
  examResultsRecorded  ExamResult[]        @relation("ExamResultRecordedBy")
  notificationsCreated Notification[]      @relation("NotificationCreatedBy")
  notifications        Notification[]      @relation("NotificationRecipient")

  @@index([schoolId, role])
  @@index([schoolId, isActive])
  @@map("users")
}

model StaffProfile {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId    String    @map("school_id") @db.Uuid
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  userId      String?   @unique @map("user_id") @db.Uuid
  user        User?     @relation("StaffUser", fields: [userId], references: [id], onDelete: SetNull)
  staffNumber String    @map("staff_number")
  firstName   String    @map("first_name")
  middleName  String?   @map("middle_name")
  lastName    String    @map("last_name")
  phoneNumber String?   @map("phone_number")
  jobTitle    String?   @map("job_title")
  department  String?
  hireDate    DateTime? @map("hire_date") @db.Date
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([schoolId, staffNumber])
  @@index([schoolId, isActive])
  @@index([schoolId, lastName, firstName])
  @@map("staff")
}

model SchoolClass {
  id                 String              @id @default(uuid()) @db.Uuid
  schoolId           String              @map("school_id") @db.Uuid
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name               String
  code               String?
  level              String?
  section            String?
  academicYear       String              @map("academic_year")
  classTeacherId     String?             @map("class_teacher_id") @db.Uuid
  classTeacher       User?               @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  enrollments        StudentEnrollment[]
  attendanceSessions AttendanceSession[]
  exams              Exam[]

  @@unique([schoolId, name, academicYear])
  @@unique([schoolId, code])
  @@index([schoolId, isActive])
  @@index([classTeacherId])
  @@map("classes")
}

model StudentProfile {
  id                String              @id @default(uuid()) @db.Uuid
  schoolId          String              @map("school_id") @db.Uuid
  school            School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  userId            String?             @unique @map("user_id") @db.Uuid
  user              User?               @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)
  admissionNumber   String              @map("admission_number")
  firstName         String              @map("first_name")
  middleName        String?             @map("middle_name")
  lastName          String              @map("last_name")
  dateOfBirth       DateTime?           @map("date_of_birth") @db.Date
  gender            String?
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  enrollments       StudentEnrollment[]
  attendanceEntries AttendanceEntry[]
  examResults       ExamResult[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, isActive])
  @@index([schoolId, lastName, firstName])
  @@map("students")
}

model StudentEnrollment {
  id                String            @id @default(uuid()) @db.Uuid
  schoolId          String            @map("school_id") @db.Uuid
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  studentId         String            @map("student_id") @db.Uuid
  student           StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  classId           String            @map("class_id") @db.Uuid
  schoolClass       SchoolClass       @relation(fields: [classId], references: [id], onDelete: Restrict)
  academicYear      String            @map("academic_year")
  status            EnrollmentStatus  @default(ACTIVE)
  enrolledAt        DateTime          @default(now()) @map("enrolled_at")
  exitedAt          DateTime?         @map("exited_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  attendanceEntries AttendanceEntry[]
  examResults       ExamResult[]

  @@unique([studentId, classId, academicYear])
  @@index([schoolId, academicYear, status])
  @@index([classId, academicYear])
  @@index([studentId, status])
  @@map("student_enrollments")
}

model AttendanceSession {
  id             String            @id @default(uuid()) @db.Uuid
  schoolId       String            @map("school_id") @db.Uuid
  school         School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classId        String            @map("class_id") @db.Uuid
  schoolClass    SchoolClass       @relation(fields: [classId], references: [id], onDelete: Restrict)
  academicYear   String            @map("academic_year")
  attendanceDate DateTime          @map("attendance_date") @db.Date
  takenById      String?           @map("taken_by_id") @db.Uuid
  takenBy        User?             @relation("AttendanceTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  entries        AttendanceEntry[]

  @@unique([schoolId, classId, academicYear, attendanceDate])
  @@index([schoolId, attendanceDate])
  @@index([classId, academicYear])
  @@index([takenById])
  @@map("attendance_sessions")
}

model AttendanceEntry {
  id                  String            @id @default(uuid()) @db.Uuid
  schoolId            String            @map("school_id") @db.Uuid
  school              School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  sessionId           String            @map("session_id") @db.Uuid
  session             AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId           String            @map("student_id") @db.Uuid
  student             StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  studentEnrollmentId String            @map("student_enrollment_id") @db.Uuid
  studentEnrollment   StudentEnrollment @relation(fields: [studentEnrollmentId], references: [id], onDelete: Restrict)
  status              AttendanceStatus
  remarks             String?
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@unique([sessionId, studentId])
  @@index([schoolId, studentId])
  @@index([schoolId, status])
  @@index([studentEnrollmentId])
  @@map("attendance_entries")
}

model Subject {
  id          String   @id @default(uuid()) @db.Uuid
  schoolId    String   @map("school_id") @db.Uuid
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name        String
  code        String?
  department  String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  exams       Exam[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@index([schoolId, isActive])
  @@map("subjects")
}

model Exam {
  id           String       @id @default(uuid()) @db.Uuid
  schoolId     String       @map("school_id") @db.Uuid
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classId      String       @map("class_id") @db.Uuid
  schoolClass  SchoolClass  @relation(fields: [classId], references: [id], onDelete: Restrict)
  subjectId    String       @map("subject_id") @db.Uuid
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  academicYear String       @map("academic_year")
  term         AcademicTerm
  title        String
  examDate     DateTime     @map("exam_date") @db.Date
  maxScore     Decimal      @map("max_score") @db.Decimal(5, 2)
  weight       Decimal?     @db.Decimal(5, 2)
  status       ExamStatus   @default(DRAFT)
  createdById  String?      @map("created_by_id") @db.Uuid
  createdBy    User?        @relation("ExamCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  results      ExamResult[]

  @@unique([schoolId, classId, subjectId, academicYear, term, title])
  @@index([schoolId, academicYear, term])
  @@index([classId, academicYear, term])
  @@index([subjectId])
  @@index([createdById])
  @@map("exams")
}

model ExamResult {
  id                  String            @id @default(uuid()) @db.Uuid
  schoolId            String            @map("school_id") @db.Uuid
  school              School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  examId              String            @map("exam_id") @db.Uuid
  exam                Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId           String            @map("student_id") @db.Uuid
  student             StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  studentEnrollmentId String            @map("student_enrollment_id") @db.Uuid
  studentEnrollment   StudentEnrollment @relation(fields: [studentEnrollmentId], references: [id], onDelete: Restrict)
  score               Decimal           @db.Decimal(5, 2)
  grade               String?
  remarks             String?
  recordedById        String?           @map("recorded_by_id") @db.Uuid
  recordedBy          User?             @relation("ExamResultRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@unique([examId, studentId])
  @@index([schoolId, studentId])
  @@index([studentEnrollmentId])
  @@index([recordedById])
  @@map("exam_results")
}

model Notification {
  id            String              @id @default(uuid()) @db.Uuid
  schoolId      String              @map("school_id") @db.Uuid
  school        School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  recipientId   String              @map("recipient_id") @db.Uuid
  recipient     User                @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Restrict)
  createdById   String?             @map("created_by_id") @db.Uuid
  createdBy     User?               @relation("NotificationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  channel       NotificationChannel @default(IN_APP)
  status        NotificationStatus  @default(PENDING)
  title         String
  message       String
  metadata      Json?
  sentAt        DateTime?           @map("sent_at")
  readAt        DateTime?           @map("read_at")
  failedAt      DateTime?           @map("failed_at")
  failureReason String?             @map("failure_reason")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([schoolId, recipientId, readAt])
  @@index([recipientId, createdAt])
  @@index([schoolId, status, channel])
  @@index([createdById])
  @@map("notifications")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  /// Nullable for platform-level actions or unauthenticated system events.
  schoolId  String?  @map("school_id") @db.Uuid
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  before    Json?
  after     Json?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([schoolId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
