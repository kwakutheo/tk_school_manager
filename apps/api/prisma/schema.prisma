generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  SUPPORT_ADMIN
  SYSTEM_AUDITOR
  SCHOOL_OWNER
  HEADMASTER
  VICE_PRINCIPAL
  SCHOOL_ADMIN
  ACADEMIC_COORDINATOR
  ADMIN_OFFICER
  TEACHER
  HEAD_OF_DEPARTMENT
  CLASS_TEACHER
  EXAM_OFFICER
  LAB_INSTRUCTOR
  SUBSTITUTE_TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  RECEPTIONIST
  LIBRARIAN
  IT_ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  TRANSFERRED
  WITHDRAWN
}

model School {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  slug               String              @unique
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  users              User[]
  classes            SchoolClass[]
  students           StudentProfile[]
  studentEnrollments StudentEnrollment[]
  auditLogs          AuditLog[]

  @@map("schools")
}

model User {
  id              String          @id @default(uuid()) @db.Uuid
  /// Nullable only for SaaS platform roles: SUPER_ADMIN, SUPPORT_ADMIN, SYSTEM_AUDITOR.
  schoolId        String?         @map("school_id") @db.Uuid
  school          School?         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  email           String          @unique
  passwordHash    String          @map("password_hash")
  role            Role
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  teachingClasses SchoolClass[]   @relation("ClassTeacher")
  studentProfile  StudentProfile? @relation("StudentUser")

  @@index([schoolId, role])
  @@index([schoolId, isActive])
  @@map("users")
}

model SchoolClass {
  id             String              @id @default(uuid()) @db.Uuid
  schoolId       String              @map("school_id") @db.Uuid
  school         School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name           String
  code           String?
  level          String?
  section        String?
  academicYear   String              @map("academic_year")
  classTeacherId String?             @map("class_teacher_id") @db.Uuid
  classTeacher   User?               @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  isActive       Boolean             @default(true) @map("is_active")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  enrollments    StudentEnrollment[]

  @@unique([schoolId, name, academicYear])
  @@unique([schoolId, code])
  @@index([schoolId, isActive])
  @@index([classTeacherId])
  @@map("classes")
}

model StudentProfile {
  id              String              @id @default(uuid()) @db.Uuid
  schoolId        String              @map("school_id") @db.Uuid
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  userId          String?             @unique @map("user_id") @db.Uuid
  user            User?               @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)
  admissionNumber String              @map("admission_number")
  firstName       String              @map("first_name")
  middleName      String?             @map("middle_name")
  lastName        String              @map("last_name")
  dateOfBirth     DateTime?           @map("date_of_birth") @db.Date
  gender          String?
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  enrollments     StudentEnrollment[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, isActive])
  @@index([schoolId, lastName, firstName])
  @@map("students")
}

model StudentEnrollment {
  id           String           @id @default(uuid()) @db.Uuid
  schoolId     String           @map("school_id") @db.Uuid
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  studentId    String           @map("student_id") @db.Uuid
  student      StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  classId      String           @map("class_id") @db.Uuid
  schoolClass  SchoolClass      @relation(fields: [classId], references: [id], onDelete: Restrict)
  academicYear String           @map("academic_year")
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime         @default(now()) @map("enrolled_at")
  exitedAt     DateTime?        @map("exited_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@unique([studentId, classId, academicYear])
  @@index([schoolId, academicYear, status])
  @@index([classId, academicYear])
  @@index([studentId, status])
  @@map("student_enrollments")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  /// Nullable for platform-level actions or unauthenticated system events.
  schoolId  String?  @map("school_id") @db.Uuid
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  before    Json?
  after     Json?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([schoolId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
