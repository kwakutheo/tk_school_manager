# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# JWT
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NODE_ENV="development"
PORT=3001
API_PREFIX="api/v1"

# Optional MTN MoMo Collections provider
MTN_MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"
MTN_MOMO_TARGET_ENVIRONMENT="sandbox"
MTN_MOMO_CURRENCY="GHS"
MTN_MOMO_CALLBACK_URL=""
MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=""
MTN_MOMO_COLLECTION_USER_ID=""
MTN_MOMO_COLLECTION_API_KEY=""

# Optional bootstrap seed
SEED_SUPER_ADMIN_EMAIL="admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe123!"
