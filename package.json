{
  "name": "tk-school-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @school-saas/api prisma:generate",
    "db:migrate": "pnpm --filter @school-saas/api prisma:migrate",
    "db:studio": "pnpm --filter @school-saas/api prisma:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.5",
    "pnpm": "11.11.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
